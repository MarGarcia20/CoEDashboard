  <script>
    // Theme toggle — respects system preference on first load, persists choice afterward
    (function initTheme() {
      const saved = localStorage.getItem('coe-dashboard-theme');
      if (saved === 'light' || saved === 'dark') {
        document.documentElement.setAttribute('data-theme', saved);
      } else {
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (prefersLight) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      }
    })();

    function toggleTheme() {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'light' ? 'dark' : 'light';
      if (next === 'dark') {
        document.documentElement.removeAttribute('data-theme');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
      localStorage.setItem('coe-dashboard-theme', next);
    }

    async function triggerRefresh(btn) {
      const label = btn.querySelector('.btn-label');
      const originalLabel = label.textContent;

      btn.disabled = true;
      label.textContent = 'Refreshing…';

      try {
        const res = await fetch('/api/refresh', {
          method: 'POST',
          headers: { 'X-Requested-With': 'coe-dashboard' },
          credentials: 'same-origin',
        });

        let data = {};
        try { data = await res.json(); } catch {}

        if (res.ok) {
          btn.classList.add('copied');
          label.textContent = 'Triggered · ready in ~60s';
          setTimeout(() => {
            btn.classList.remove('copied');
            label.textContent = originalLabel;
            btn.disabled = false;
          }, 8000);
        } else {
          // Show the real error so the user (or admin) can act on it.
          const msg = data.error || `Error ${res.status}`;
          label.textContent = msg.length > 40 ? msg.slice(0, 37) + '…' : msg;
          console.error('Refresh failed:', res.status, data);
          btn.disabled = false;
          setTimeout(() => { label.textContent = originalLabel; }, 6000);
        }
      } catch (err) {
        console.error('Refresh network error:', err);
        label.textContent = 'Network error — retry';
        btn.disabled = false;
        setTimeout(() => { label.textContent = originalLabel; }, 6000);
      }
    }

    // Localize snapshot timestamp to the viewer's timezone + keep "X ago" fresh.
    // All <time class="snapshot-time"> elements get their text replaced with
    // the viewer's local date/time. The footer #age-indicator also gets an
    // "Xm ago / Xh ago / Xd ago" suffix that ticks every minute.
    (function() {
      const snapshotTime = new Date('{{ snapshot_iso }}');
      if (isNaN(snapshotTime.getTime())) return;

      function fmtLocalDate() {
        return snapshotTime.toLocaleDateString(undefined, {
          month: 'long', day: 'numeric', year: 'numeric'
        });
      }
      function fmtLocalTime() {
        return snapshotTime.toLocaleTimeString(undefined, {
          hour: 'numeric', minute: '2-digit'
        });
      }
      function fmtTzAbbrev() {
        // Short timezone name ("EDT", "CET", etc.). Fallback to offset.
        try {
          const parts = new Intl.DateTimeFormat(undefined, {
            timeZoneName: 'short'
          }).formatToParts(snapshotTime);
          const tz = parts.find(p => p.type === 'timeZoneName');
          return tz ? tz.value : '';
        } catch {
          return '';
        }
      }
      const localDate = fmtLocalDate();
      const localTime = fmtLocalTime();
      const tz = fmtTzAbbrev();
      const localFull = `${localDate} · ${localTime}${tz ? ' ' + tz : ''}`;

      // Replace any elements marked with data-snapshot-time
      const shortDate = snapshotTime.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
      document.querySelectorAll('[data-snapshot-time]').forEach(el => {
        const mode = el.getAttribute('data-snapshot-time');
        if (mode === 'full')    el.textContent = localFull;
        if (mode === 'date')    el.textContent = localDate;
        if (mode === 'time')    el.textContent = `${localTime}${tz ? ' ' + tz : ''}`;
        if (mode === 'short')   el.textContent = `${shortDate} · ${localTime}${tz ? ' ' + tz : ''}`;
        if (mode === 'eyebrow') el.textContent = `Snapshot · ${shortDate} · ${localTime}${tz ? ' ' + tz : ''}`;
      });

      const indicator = document.getElementById('age-indicator');
      if (!indicator) return;

      function ageStr() {
        const diffMs = Date.now() - snapshotTime.getTime();
        const diffMin = Math.floor(diffMs / 60000);
        const diffHr = Math.floor(diffMin / 60);
        const diffDay = Math.floor(diffHr / 24);
        if (diffMin < 1) return 'just now';
        if (diffMin < 60) return `${diffMin}m ago`;
        if (diffHr < 24) return `${diffHr}h ago`;
        return `${diffDay}d ago`;
      }
      function updateAge() {
        indicator.textContent = `Snapshot · ${localFull} · ${ageStr()}`;
      }
      updateAge();
      setInterval(updateAge, 60000);
    })();
  </script>
</body>
</html>
